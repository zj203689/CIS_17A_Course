//System Libraries Here
#include <iostream>
#include <iomanip>
using namespace std;

//User Libraries Here

//Global Constants Only, No Global Variables
//Like PI, e, Gravity, or conversions

//Function Prototypes Here

//Program Execution Begins Here
int main(int argc, char** argv) {
    //Declare all Variables Here
    bool x,y;


    //Display the Heading
    cout<<"X Y !X !Y X&&Y X||Y X^Y X^Y^X X^Y^Y !(X&&Y) !X||!Y "<<
          " !(X||Y) !X&&!Y"<<endl;
    //take inputs 
    while(cin>>x>>y&&x>=0){
        cout<<(x?'T':'F')<<" "
            <<(y?'T':'F')<<"  "
            <<(!x?'T':'F')<<"  "
            <<(!y?'T':'F')<<"   "
            <<(x&&y?'T':'F')<<setw(5)
            <<(x||y?'T':'F')<<setw(4)
            <<(x^y?'T':'F')<<setw(5)
            <<((x^y)^x?'T':'F')<<setw(6)
            <<((x^y)^y?'T':'F')<<setw(8)
            <<(!(x&&y)?'T':'F')<<setw(7)
            <<(!x||!y?'T':'F')<<setw(9)
            <<(!(x||y)?'T':'F')<<setw(7)
            <<(!x&&!y?'T':'F')
            <<endl;
    }
    cout<<endl;
    

    //Exit
    return 0;
}
